# Copy to .env.local and adjust. Never commit .env.local!
#
# The frontend proxies /api/* to the backend (see next.config.ts), so the
# browser only talks to this origin and the auth cookie stays first-party.

# Backend the proxy forwards to (server-side, read at build time).
# Defaults to http://localhost:4000 — only set this to override locally.
BACKEND_INTERNAL_URL="http://localhost:4000"
