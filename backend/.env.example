# Copy to .env and adjust for your environment. Never commit .env!

# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas_light?schema=public"

# Secret used to sign JWTs – generate e.g. via `openssl rand -hex 32`
JWT_SECRET="change-me-to-a-long-random-string"

# Lifetime of issued JWTs / auth cookies
JWT_EXPIRES_IN="7d"

# Port the Express server listens on
PORT=4000

# Origin of the Next.js frontend (CORS allowlist, credentials enabled)
FRONTEND_ORIGIN="http://localhost:3000"
